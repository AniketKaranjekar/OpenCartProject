<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">
  <groups>
    <run>
      <!--include name=""></include-->
    </run>
  </groups>

  <listeners>
    <listener class-name="listeners.TestListener" />
  </listeners>

  <test thread-count="1" name="Test">
    <parameter name="browser" value="edge"></parameter>
    <classes>
      <class name="tests.RegistrationTest" />
      <class name="tests.LoginTest" />
      <class name="tests.SearchProductTest" />
      <class name="tests.AddToCartTest" />
      <class name="tests.WishListTest" />
      <class name="tests.ShoppingCartTest" />
      <class name="tests.LoginDDTTest" />
    </classes>
  </test>
